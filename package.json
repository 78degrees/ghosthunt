{
  "name": "ghosthunt",
  "version": "1.0.1",
  "mcpName": "io.github.78degrees/ghosthunt",
  "description": "Find every leaked secret on your machine — API keys in .env files, shell history, and configs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ghosthunt": "bin/ghosthunt.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "secrets",
    "secret-scanning",
    "api-keys",
    "credentials",
    "dotenv",
    "shell-history",
    "developer-tools",
    "claude",
    "ai-tools",
    "devops",
    "devsec"
  ],
  "author": "GhostHunt <hello@ghosthunt.dev>",
  "license": "MIT",
  "homepage": "https://ghosthunt.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/78degrees/ghosthunt.git"
  },
  "bugs": {
    "url": "https://github.com/78degrees/ghosthunt/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0"
  }
}
